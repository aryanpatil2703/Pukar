# Server
PORT=3000

# Telnyx
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PUBLIC_KEY=your_telnyx_public_key
TELNYX_CONNECTION_ID=your_telnyx_connection_id

# Deepgram (STT)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq (Intent Classification)
GROQ_API_KEY=your_groq_api_key

# Redis
REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/callbot

# Call Configuration
TRANSFER_NUMBER=+919049898988
COMPANY_NAME=Salesgarners
